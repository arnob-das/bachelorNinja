<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Mess Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        .dropdown:hover .dropdown-menu {
            display: block;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("Mess Management", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">@Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    @if (Session["UserId"] != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDashboardDropdown" role="button">
                                User Dashboard
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="userDashboardDropdown">
                                <li>@Html.ActionLink("User Dashboard", "Index", "UserDashboard", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Join Mess", "JoinMess", "UserDashboard", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>
                    }
                    @if (Session["ManagerId"] != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="managerDashboardDropdown" role="button">
                                Manager Dashboard
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="managerDashboardDropdown">
                                <li>@Html.ActionLink("Manager Dashboard", "Dashboard", "Manager", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Approve Users", "ApproveUsers", "Manager", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Assign Bills", "AssignUtilityBills", "Manager", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Set Rent", "SetRoomRent", "Manager", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Create Mess", "CreateMess", "Manager", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>
                    }

                    @if (Session["isAuthenticated"] == null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="loginDropdown" role="button">
                                Login
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="loginDropdown">
                                <li>@Html.ActionLink("Manager Login", "ManagerLogin", "Login", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("User Login", "UserLogin", "Login", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>
                    }

                    @if (Session["isAuthenticated"] == null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="registrationDropdown" role="button">
                                Registration
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="registrationDropdown">
                                <li>@Html.ActionLink("Manager Registration", "ManagerRegister", "Register", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("User Registration", "UserRegister", "Register", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>
                    }

                    @if (Session["ManagerId"] != null)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Manager Profile", "Details", "ManagerProfile", new { id = Session["ManagerId"] }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Logout", "Logout", "Login", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    @if (Session["UserId"] != null)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("User Profile", "Details", "UserProfile", new { id = Session["UserId"] }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Logout", "Logout", "Login", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Mess Management System - Developed by - Arnob, Anika, Fargin</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWi70geYac+LfBCBBY3Rkaazwv3a6j6qmGhHu91pG9KRlEVoWWRMllEyeb" crossorigin="anonymous"></script>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
